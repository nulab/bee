---
import { Card, Code, Tabs, TabItem } from "@astrojs/starlight/components";
---

<div class="install-command">
  <Card title="インストール" icon="laptop">
    <p>ワンコマンドですぐに使い始められます。</p>
    <Tabs>
      <TabItem label="npm">
        <Code code="npm install -g @nulab/bee" lang="sh" />
      </TabItem>
      <TabItem label="pnpm">
        <Code code="pnpm add -g @nulab/bee" lang="sh" />
      </TabItem>
      <TabItem label="bun">
        <Code code="bun add -g @nulab/bee" lang="sh" />
      </TabItem>
      <TabItem label="nypm">
        <Code code="npx nypm install -g @nulab/bee" lang="sh" />
      </TabItem>
    </Tabs>
  </Card>
</div>

<style>
  .install-command {
    width: 640px;
    max-width: 100%;
    margin-inline: auto;
  }

</style>
