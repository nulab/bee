---
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
import { Code } from "@astrojs/starlight/components";
import { marked } from "marked";
import { loadCommands } from "../../lib/commands";
import type { CommandEntry } from "../../lib/commands";

const renderMarkdown = (text: string) => marked.parse(text, { async: false }) as string;

export async function getStaticPaths() {
  const commands = await loadCommands();
  return commands.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;

type Arg = CommandEntry["args"][number];

// Build usage line
const flags = entry.args.filter((a: Arg) => a.type !== "positional");
const positionals = entry.args.filter((a: Arg) => a.type === "positional");
const usageParts: string[] = [];
if (flags.length > 0) usageParts.push("[flags]");
for (const arg of positionals) {
  const name = arg.name.toUpperCase();
  usageParts.push(
    arg.required !== false && arg.default === undefined
      ? `<${name}>`
      : `[${name}]`,
  );
}
const usageLine = `${entry.title} ${usageParts.join(" ")}`.trim();

// Format flag display
const formatFlag = (arg: Arg) => {
  const short = arg.alias.map((a: string) => `-${a}`).join(", ");
  const long = `--${arg.name}`;
  const flag = short ? `${short}, ${long}` : long;
  const hint =
    arg.type === "string" ? (arg.valueHint ? ` ${arg.valueHint}` : " <string>") : "";
  return `${flag}${hint}`;
};
---

<StarlightPage
  frontmatter={{
    title: entry.title,
    description: entry.description,
  }}
>
  {
    entry.long && (
      <div
        set:html={entry.long
          .split("\n\n")
          .map((p: string) => `<p>${p}</p>`)
          .join("")}
      />
    )
  }

  <h2>Usage</h2>
  <Code code={usageLine} lang="sh" />

  {
    positionals.length > 0 && (
      <>
        <h2>Arguments</h2>
        <dl>
          {positionals.map((arg: Arg) => (
            <>
              <dt>
                <code>{arg.name.toUpperCase()}</code>
              </dt>
              <dd>
                {arg.description ?? ""}
                {arg.default !== undefined && (
                  <>
                    {" "}
                    (default: <code>{String(arg.default)}</code>)
                  </>
                )}
              </dd>
            </>
          ))}
        </dl>
      </>
    )
  }

  {
    flags.length > 0 && (
      <>
        <h2>Flags</h2>
        <dl>
          {flags.map((arg: Arg) => (
            <>
              <dt>
                <code>{formatFlag(arg)}</code>
              </dt>
              <dd>
                {arg.description ?? ""}
                {arg.default !== undefined && (
                  <>
                    {" "}
                    (default: <code>{String(arg.default)}</code>)
                  </>
                )}
              </dd>
            </>
          ))}
        </dl>
      </>
    )
  }

  {
    entry.examples &&
      entry.examples.length > 0 && (
        <>
          <h2>Examples</h2>
          {entry.examples.map((ex: { description: string; command: string }) => (
            <>
              <p>{ex.description}</p>
              <Code code={`$ ${ex.command}`} lang="sh" />
            </>
          ))}
        </>
      )
  }

  {
    entry.environment &&
      entry.environment.length > 0 && (
        <>
          <h2>Environment variables</h2>
          <dl>
            {entry.environment.map(([key, desc]: [string, string]) => (
              <>
                <dt>
                  <code>{key}</code>
                </dt>
                <dd>{desc}</dd>
              </>
            ))}
          </dl>
        </>
      )
  }
</StarlightPage>
