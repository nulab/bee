{
  "name": "@nulab/bee",
  "version": "0.0.0",
  "description": "bee — a CLI for Backlog",
  "keywords": [
    "backlog",
    "cli",
    "nulab",
    "project-management"
  ],
  "homepage": "https://nulab.github.io/bee",
  "bugs": {
    "url": "https://github.com/nulab/bee/issues"
  },
  "license": "MIT",
  "author": "Nulab Inc.",
  "repository": {
    "type": "git",
    "url": "git://github.com/nulab/bee.git",
    "directory": "apps/cli"
  },
  "bin": {
    "bee": "bin/cli.mjs"
  },
  "files": [
