    "citty": "^0.2.1",
    "consola": "^3.4.2",
    "is-unicode-supported": "^2.1.0",
    "open": "^11.0.0",
    "ufo": "^1.5.4",
    "valibot": "^1.2.0"
  },
  "devDependencies": {
    "@repo/test-utils": "workspace:*",
    "@repo/tsconfigs": "workspace:*",
    "tsx": "^4.19.0",
    "unbuild": "^3.5.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
