{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": ["@tsconfig/node-lts/tsconfig.json", "@tsconfig/node-ts/tsconfig.json"],
  "compilerOptions": {
    "module": "preserve",
    "moduleResolution": "bundler",
    "rewriteRelativeImportExtensions": false,
    "composite": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationMap": true,
    "types": ["node"]
  }
}
