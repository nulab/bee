{
  "private": true,
  "license": "MIT",
  "repository": "nulab/backlog-cli",
  "scripts": {
    "postinstall": "lefthook install",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "typecheck": "oxlint --type-aware --type-check --ignore-pattern 'apps/docs'",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test": "vitest run"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "lefthook": "^2.1.2",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "oxlint-tsgolint": "^0.16.0",
    "turbo": "^2.8.13",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lefthook",
      "sharp",
      "turbo"
    ]
  }
}
